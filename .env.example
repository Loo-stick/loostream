# LooStream Configuration

# Port du serveur
PORT=7002

# Proxy mode:
#   false (défaut) = MediaFlow (recommandé pour usage public, économise la bande passante)
#   true = Proxy local (pour usage perso, tout passe par ton serveur)
USE_LOCAL_PROXY=false

# MediaFlow (requis si USE_LOCAL_PROXY=false)
MEDIAFLOW_URL=https://your-mediaflow-instance.com
MEDIAFLOW_PASSWORD=your_password_here

# TMDB API Key (gratuit sur themoviedb.org)
TMDB_API_KEY=your_tmdb_api_key_here
